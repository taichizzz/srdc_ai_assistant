# Copy this file to local.properties; local.properties is intentionally gitignored.
# Set sdk.dir to the Android SDK path on this development machine.
sdk.dir=/absolute/path/to/Android/sdk

# Non-secret GCP project used for Speech-to-Text quota attribution.
# The Speech-to-Text API and billing/quota must already be enabled for this project.
GCP_STT_PROJECT_ID=

# DEBUG BUILDS ONLY: V2 regional endpoint/recognizer location used for Chirp evaluation.
# asia-southeast1 is the default because current Google documentation lists Taiwan Mandarin for
# Chirp 2 there and Chirp 3 is regionally available there. Model/region availability can change;
# confirm it with Google's Locations API before a formal comparison. Release builds keep this empty.
GCP_STT_LOCATION=asia-southeast1

# DEBUG BUILDS ONLY: paste a short-lived OAuth access token generated with:
#   gcloud auth print-access-token
# Or inject it for one build without saving it:
#   GCP_STT_ACCESS_TOKEN="$(gcloud auth print-access-token)" ./gradlew installDebug
# The token normally expires after about one hour. STT V2 Chirp and Gemini-TTS prefer this bearer
# because both paths are IAM-gated; the same cloud-platform token may serve both when the service
# account has their required roles. Never paste a service-account JSON, refresh token, private key,
# or other long-lived credential here. Production must use an approved organization token broker
# instead of packaging a developer token.
GCP_STT_ACCESS_TOKEN=

# DEBUG BUILDS ONLY: Vertex AI project used by the primary LM intent interpreter. Keep this
# distinct from GCP_STT_PROJECT_ID unless both APIs are intentionally enabled and billed in the
# same project. Release builds keep this empty.
GCP_LM_PROJECT_ID=

# DEBUG BUILDS ONLY: regional Vertex AI endpoint. The Phase 5 mock-tested default is us-central1.
# Confirm regional model availability and company data-residency policy before live acceptance.
GCP_LM_LOCATION=us-central1

# DEBUG BUILDS ONLY: stable Flash-tier publisher model. gemini-2.5-flash is the documented GA model
# selected for Phase 5; override this only after confirming another model is enabled in the project.
GCP_LM_MODEL=gemini-2.5-flash

# Vertex uses the short-lived bearer token above; no service-account JSON is read by the app.
# Mint a token locally with one of:
#   gcloud auth print-access-token
#   gcloud auth print-access-token --impersonate-service-account=NAME@PROJECT.iam.gserviceaccount.com
# The caller needs Vertex AI inference permission in GCP_LM_PROJECT_ID. Never place a service-account
# JSON, private key, refresh token, or other long-lived credential in this file or the APK.

# DEBUG BUILDS ONLY: plain Google Cloud API key string (commonly starts with AIza...).
# V1 STT and classic WaveNet TTS prefer this key. V2 Chirp and Gemini-TTS prefer the bearer token
# above because their model calls are IAM-gated, while retaining the key as a fallback when no token
# exists. Exactly one credential is sent per request. Restrict the key in Google Cloud Console to
# the enabled APIs and, where company policy supports it, to package com.foxconn.seeandsay plus the
# signing certificate SHA-1. Never paste a service-account JSON, private key, or other credential
# file here, and never commit the real value to VCS.
GCP_STT_API_KEY=

# DEBUG behavior flag: true tries Cloud TTS first and falls back to the Android device engine;
# false skips all Cloud TTS credential/network work and uses the device engine directly.
# Release/default builds use true. This is not a credential and must contain only true or false.
CLOUD_TTS_ENABLED=true

# DEBUG behavior flag: true uses the LM as the primary interpreter for every non-empty utterance;
# false skips provider construction and uses deterministic TextMatcher fallback only. Production and
# release default to true, while release still carries empty LM project/location/model/token fields;
# missing configuration must recover through deterministic matching rather than crash.
LM_ENABLED=true
